{
  "name": "orb-ui",
  "version": "0.2.1",
  "description": "The simplest way to add voice UI to your React app. One install, one component, works with Vapi and ElevenLabs out of the box.",
  "type": "module",
  "main": "./dist/orb-ui.cjs",
  "module": "./dist/orb-ui.js",
  "types": "./dist/orb-ui.d.ts",
  "exports": {
    ".": {
      "import": "./dist/orb-ui.js",
      "require": "./dist/orb-ui.cjs",
      "types": "./dist/orb-ui.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs",
      "types": "./dist/adapters.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "voice",
    "voice-ui",
    "voice-agent",
    "ai",
    "react",
    "animation",
    "component",
    "state-machine",
    "vapi",
    "elevenlabs"
  ],
  "license": "MIT",
  "author": "Alexander Chen",
  "homepage": "https://orb-ui-demo.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexanderqchen/orb-ui.git"
  },
  "dependencies": {},
  "typesVersions": {
    "*": {
      "adapters": [
        "./dist/adapters.d.ts"
      ]
    }
  }
}
