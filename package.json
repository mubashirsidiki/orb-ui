{
  "name": "orb-ui",
  "version": "0.2.3",
  "description": "The simplest way to add voice UI to your React app. One install, one component, works with Vapi and ElevenLabs out of the box.",
  "type": "module",
  "main": "./dist/orb-ui.cjs",
  "module": "./dist/orb-ui.js",
  "types": "./dist/orb-ui.d.ts",
  "exports": {
    ".": {
      "import": "./dist/orb-ui.js",
      "require": "./dist/orb-ui.cjs",
      "types": "./dist/orb-ui.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs",
      "types": "./dist/adapters.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:demo": "pnpm --filter orb-ui-demo build",
    "changeset": "changeset",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm build:demo",
    "dev": "vite build --watch",
    "dev:demo": "pnpm --filter orb-ui-demo dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "release": "pnpm build && changeset publish",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "voice",
    "voice-ui",
    "voice-agent",
    "ai",
    "react",
    "animation",
    "component",
    "state-machine",
    "vapi",
    "elevenlabs"
  ],
  "license": "MIT",
  "author": "Alexander Chen",
  "homepage": "https://orb-ui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexanderqchen/orb-ui.git"
  },
  "packageManager": "pnpm@10.33.1",
  "typesVersions": {
    "*": {
      "adapters": [
        "./dist/adapters.d.ts"
      ]
    }
  }
}
