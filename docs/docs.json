{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "orb-ui",
  "description": "React voice agent UI components for Vapi, ElevenLabs, LiveKit, Pipecat, OpenAI Realtime, Gemini Live, and custom voice AI apps.",
  "colors": {
    "primary": "#4da3ff",
    "light": "#9fd2ff",
    "dark": "#1f6feb"
