        "label": "Home",
        "href": "https://orb-ui.com"
      },
      {
        "type": "github",
        "href": "https://github.com/alexanderqchen/orb-ui"
      }
    ],
    "primary": {
      "type": "button",
      "label": "npm",
      "href": "https://www.npmjs.com/package/orb-ui"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/alexanderqchen/orb-ui",
      "website": "https://orb-ui.com"
    }
