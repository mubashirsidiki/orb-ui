# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# Your Vapi public API key (from dashboard.vapi.ai → API Keys → Public Key)
VITE_VAPI_PUBLIC_KEY=

# The Vapi assistant ID to call when the user clicks Start
# (from dashboard.vapi.ai → Assistants → your assistant → copy the ID from the URL)
VITE_VAPI_ASSISTANT_ID=

# Your ElevenLabs Conversational AI agent ID.
VITE_ELEVENLABS_AGENT_ID=

# LiveKit playground mode: sandbox, endpoint, or raw
VITE_LIVEKIT_MODE=sandbox

# LiveKit Cloud sandbox token server ID (e.g. token-server-abc123)
VITE_LIVEKIT_SANDBOX_ID=

# Your LiveKit Agents dispatch name.
VITE_LIVEKIT_AGENT_NAME=

# Room names are generated as `${prefix}-${randomUUID()}` for each start.
VITE_LIVEKIT_ROOM_PREFIX=orb-ui-playground

# Production/testing token endpoint that returns { serverUrl, participantToken }.
VITE_LIVEKIT_TOKEN_ENDPOINT=

# Advanced raw connection details.
VITE_LIVEKIT_SERVER_URL=

# A short-lived LiveKit participant token.
VITE_LIVEKIT_PARTICIPANT_TOKEN=

# Pipecat playground mode: cloud or small-webrtc.
# Standard/public API keys are entered in the playground and are never bundled from VITE_* vars.
VITE_PIPECAT_MODE=cloud
VITE_PIPECAT_AGENT_NAME=
VITE_PIPECAT_WEBRTC_URL=

# Public, non-secret OpenAI Realtime session defaults.
VITE_OPENAI_REALTIME_MODEL=gpt-realtime-2.1
VITE_OPENAI_REALTIME_VOICE=marin
VITE_OPENAI_REALTIME_INSTRUCTIONS=You are a concise, friendly voice assistant helping test a realtime React UI.

# Public, non-secret Gemini Live session defaults.
VITE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
VITE_GEMINI_LIVE_VOICE=Kore
VITE_GEMINI_LIVE_INSTRUCTIONS=You are a concise, friendly voice assistant helping test a realtime React UI.
