{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "rootDir": "../..",
    "skipLibCheck": true,
    "types": ["@playwright/test"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../../playwright.config.ts"]
}
